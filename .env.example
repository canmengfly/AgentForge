# Copy to .env and adjust as needed

# ── Embedding ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2   # 384-dim
# EMBEDDING_MODEL=all-mpnet-base-v2  # 768-dim, higher quality
EMBEDDING_DEVICE=cpu                # or cuda
EMBEDDING_DIM=384                   # must match model above

# ── Chunking ───────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Vector backend ─────────────────────────────────────────────────────────
# Option A: ChromaDB (default, no extra setup)
VECTOR_BACKEND=chroma

# Option B: PostgreSQL + pgvector
# 1. Install pgvector: https://github.com/pgvector/pgvector
# 2. In psql: CREATE EXTENSION IF NOT EXISTS vector;
# 3. Uncomment and fill in below:
# VECTOR_BACKEND=pgvector
# PG_VECTOR_URL=postgresql://user:password@localhost:5432/akp

# ── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# API_KEY=your-secret-key   # optional: protect all API endpoints

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRE_MINUTES=10080   # 7 days
