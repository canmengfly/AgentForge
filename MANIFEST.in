include README.md
include README_ZH.md
include LICENSE
recursive-include src/templates *.html
recursive-include src/static *.svg *.css *.js *.png *.ico *.woff *.woff2 *.ttf
recursive-include docs *.md

# Exclude everything that must never ship
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.DS_Store
global-exclude .env
global-exclude .env.*
prune data
prune dist
prune tests
prune .venv
prune .git
prune .claude
prune *.egg-info
